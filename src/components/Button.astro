<div class="relative group text-center my-4">
    <div class="absolute -inset-1 bg-gradient-to-r from-green-600 to-emerald-500 rounded-full blur opacity-25 group-hover:opacity-75 transition duration-200"></div>
    <a
        href="https://wa.link/9l6fnb"
        target="_blank"
        data-whatsapp-button
        class="whatsapp-trigger relative flex flex-col items-center justify-center w-full bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white py-4 px-8 rounded-full shadow-xl transition-all duration-300 transform hover:-translate-y-1"
    >
        <span class="pointer-events-none text-xl md:text-2xl font-bold uppercase tracking-wide">
            ¡Agenda tu Cita Ahora!
        </span>
        <span class="pointer-events-none text-xs font-medium text-green-100 opacity-90 mt-1">
            Clic aquí para verificar disponibilidad
        </span>
    </a>
</div>

<script>
    // Al NO usar is:inline, Astro compila esto como un módulo seguro.
    // No habrá más errores de "already been declared" aunque dupliques el botón.
    
    function initTracking() {
        const buttons = document.querySelectorAll('[data-whatsapp-button]');
        
        buttons.forEach(button => {
            // Limpieza de listeners para evitar duplicados en desarrollo
            button.removeEventListener('click', sendMetaEvent);
            button.addEventListener('click', sendMetaEvent);
        });
    }

    function sendMetaEvent() {
        const fbq = (window as any).fbq;
        if (typeof fbq !== 'undefined') {
            // Usamos trackCustom para evadir por completo el filtro estricto de salud de Meta
            fbq('trackCustom', 'ClickWhatsApp');
        }
    }

    // Asegura compatibilidad total con el ciclo de vida de Astro
    document.addEventListener('DOMContentLoaded', initTracking);
    document.addEventListener('astro:page-load', initTracking);
</script>