---
import Button from "./Button.astro";    
---

<div class="relative w-full bg-[#050505] overflow-hidden py-12 lg:py-24">
    <div
        class="absolute top-1/2 left-0 -translate-y-1/2 w-[600px] h-[600px] bg-neutral-800/40 rounded-full blur-[80px] -z-0 pointer-events-none"
    >
    </div>

    <div
        class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-yellow-600/20 rounded-full blur-[100px] -z-0 pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center"
        >
            <div class="lg:col-span-6 text-left space-y-8 order-2 md:order-1">
                <div
                    class="flex justify-center mx-auto w-fit md:inline-flex items-center gap-2 bg-yellow-950/30 border border-yellow-500/40 rounded-full pl-2 pr-4 py-1.5 mb-2 shadow-[0_0_15px_rgba(234,179,8,0.2)]"
                >
                    <span class="flex h-2 w-2 relative">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"
                        ></span>
                    </span>
                    <span
                        class="text-yellow-100 text-xs md:text-sm font-bold uppercase tracking-wider"
                        >Exclusivo Mujeres</span
                    >
                </div>

                <div>
                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl text-center md:text-left font-bold text-white leading-tight mb-4 drop-shadow-lg"
                    >
                        Si cada año <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-yellow-500"
                            >prometes tu gran cambio...</span
                        >
                    </h2>

                    <h1
                        class="text-xl md:text-2xl font-medium text-neutral-200 leading-relaxed text-center md:text-left"
                    >
                        Este es el que SÍ hará realidad tu <span
                            class="text-white font-bold underline decoration-yellow-500 decoration-2 underline-offset-4"
                            >Bikini Body
                        </span> — ese cuerpo listo para el verano que siempre has
                        querido.
                    </h1>
                </div>

                <p
                    class="text-neutral-300 text-lg leading-relaxed border-l-4 border-yellow-500 pl-5"
                >
                    Con el <strong class="text-yellow-300"
                        >Dr. Miguel Ángel</strong
                    >, cirujano plástico certificado y especialista en
                    transformar vidas.
                </p>

                <div
                    class="flex flex-wrap gap-2 sm:gap-3 pt-2 justify-center sm:justify-start"
                >
                    <div
                        class="flex items-center gap-3 bg-neutral-900/80 backdrop-blur-md border border-neutral-700/50 ring-1 ring-yellow-500/20 rounded-xl px-2 sm:px-5 py-1 sm:py-3 shadow-lg hover:bg-neutral-800 transition-all duration-300 group"
                    >
                        <div
                            class="bg-yellow-500/20 p-1.5 rounded-full group-hover:bg-yellow-500/30 transition"
                        >
                            <svg
                                class="w-3 sm:w-5 h-3 sm:h-5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path></svg
                            >
                        </div>
                        <span
                            class="text-[10px] sm:text-base font-medium text-white tracking-wide"
                            >Resultados Reales
                        </span>
                    </div>

                    <div
                        class="flex items-center gap-3 bg-neutral-900/80 backdrop-blur-md border border-neutral-700/50 ring-1 ring-yellow-500/20 rounded-xl px-2 sm:px-5 py-1 sm:py-3 shadow-lg hover:bg-neutral-800 transition-all duration-300 group"
                    >
                        <div
                            class="bg-yellow-500/20 p-1.5 rounded-full group-hover:bg-yellow-500/30 transition"
                        >
                            <svg
                                class="w-3 sm:w-5 h-3 sm:h-5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path></svg
                            >
                        </div>
                        <span
                            class="text-[10px] sm:text-base font-medium text-white tracking-wide"
                            >Tecnología de Punta
                        </span>
                    </div>

                    <div
                        class="flex items-center gap-3 bg-neutral-900/80 backdrop-blur-md border border-neutral-700/50 ring-1 ring-yellow-500/20 rounded-xl px-2 sm:px-5 py-1 sm:py-3 shadow-lg hover:bg-neutral-800 transition-all duration-300 group"
                    >
                        <div
                            class="bg-yellow-500/20 p-1.5 rounded-full group-hover:bg-yellow-500/30 transition"
                        >
                            <svg
                                class="w-3 sm:w-5 h-3 sm:h-5 text-yellow-400"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                ><path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path></svg
                            >
                        </div>
                        <span
                            class="text-[10px] sm:text-base font-medium text-white tracking-wide"
                            >Lipoescultura + Mamoplastía</span
                        >
                    </div>
                </div>
            </div>
            <div class="lg:col-span-6 w-full flex flex-col gap-8 order-1">
                <div class="relative group/video">
                    <div
                        class="absolute -inset-[1px] bg-gradient-to-b from-yellow-500/30 to-neutral-900 rounded-2xl opacity-100 z-0"
                    >
                    </div>

                    <div
                        class="relative rounded-2xl overflow-hidden shadow-[0_0_40px_-10px_rgba(0,0,0,0.7)] bg-black z-10"
                    >
                        <video
                            id="mainVideo"
                            class="w-full aspect-video object-cover"
                            controlslist="nodownload nofullscreen noremoteplayback"
                            autoplay
                            loop
                            muted
                            playsinline
                            webkit-playsinline
                        >
                            <source
                                src="/landing_miguel.mp4"
                                type="video/mp4"
                            />
                            <source src="../assets/1023.mp4" type="video/mp4" />
                        </video>

                        <div
                            id="container-open"
                            class="absolute inset-0 cursor-pointer flex items-center justify-center bg-black/20 hover:bg-black/10 transition-all duration-500 z-20 group/btn"
                        >
                            <div
                                class="relative flex items-center justify-center"
                            >
                                <div
                                    class="absolute inset-0 rounded-full bg-yellow-500/30 blur-xl transform group-hover/btn:scale-125 transition-transform duration-500"
                                >
                                </div>

                                <div
                                    class="relative w-24 h-24 md:w-28 md:h-28 rounded-full bg-black/40 backdrop-blur-sm border-[2px] border-yellow-400 shadow-[0_0_30px_rgba(250,204,21,0.3)] flex items-center justify-center transition-all duration-300 group-hover/btn:scale-105 group-hover/btn:bg-black/50 group-hover/btn:shadow-[0_0_50px_rgba(250,204,21,0.5)]"
                                >
                                    <svg
                                        class="w-10 h-10 md:w-12 md:h-12 text-yellow-400 ml-2 drop-shadow-lg"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path d="M8 5v14l11-7z"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div
                            id="centralPlayIndicator"
                            class="absolute inset-0 flex items-center justify-center pointer-events-none z-30 hidden opacity-0"
                        >
                        </div>

                        <div
                            id="customControls"
                            class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/70 to-transparent p-4 opacity-0 transition-opacity duration-300 z-30 hidden"
                        >
                            <div class="flex items-center gap-3">
                                <button
                                    id="playPauseBtn"
                                    class="text-white hover:text-yellow-400 transition-colors"
                                >
                                    <svg
                                        id="playIcon"
                                        class="w-8 h-8 hidden"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path d="M8 5v14l11-7z"></path></svg
                                    >
                                    <svg
                                        id="pauseIcon"
                                        class="w-8 h-8"
                                        fill="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"
                                        ></path></svg
                                    >
                                </button>
                                <div class="flex-1">
                                    <input
                                        type="range"
                                        id="progressBar"
                                        class="w-full h-1 bg-neutral-600 rounded-lg appearance-none cursor-pointer accent-yellow-500"
                                        min="0"
                                        max="100"
                                        value="0"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <Button />
            </div>
        </div>
    </div>
</div>
<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const video = document.getElementById("mainVideo");
        const overlayBtn = document.getElementById("container-open"); // El botón grande de activar audio
        const customControls = document.getElementById("customControls");

        // Iconos y botones de control
        const playPauseBtn = document.getElementById("playPauseBtn");
        const playIcon = document.getElementById("playIcon");
        const pauseIcon = document.getElementById("pauseIcon");
        const progressBar = document.getElementById("progressBar");

        // 1. LÓGICA DEL BOTÓN "ACTIVAR AUDIO"
        if (overlayBtn && video) {
            overlayBtn.addEventListener("click", () => {
                // Activar sonido
                video.muted = false;
                video.currentTime = 0; // Reiniciar video desde el principio (opcional)

                // Reproducir (esto evita pantalla completa porque es un play programático inline)
                video
                    .play()
                    .then(() => {
                        // Ocultar el overlay de "Activar Audio"
                        overlayBtn.classList.add("hidden");

                        // Mostrar la barra de controles inferior
                        customControls.classList.remove("hidden");
                        customControls.classList.remove("opacity-0");

                        // Actualizar iconos
                        updateIcons(true);
                    })
                    .catch((error) => {
                        console.log("Error al reproducir:", error);
                    });
            });
        }

        // 2. LÓGICA DE LOS CONTROLES INFERIORES (Play/Pause)
        playPauseBtn.addEventListener("click", () => {
            if (video.paused) {
                video.play();
                updateIcons(true);
            } else {
                video.pause();
                updateIcons(false);
            }
        });

        // Actualizar barra de progreso
        video.addEventListener("timeupdate", () => {
            const percentage = (video.currentTime / video.duration) * 100;
            progressBar.value = percentage;
        });

        // Permitir arrastrar la barra
        progressBar.addEventListener("input", (e) => {
            const time = (progressBar.value / 100) * video.duration;
            video.currentTime = time;
        });

        // Función auxiliar para cambiar iconos
        function updateIcons(isPlaying) {
            if (isPlaying) {
                playIcon.classList.add("hidden");
                pauseIcon.classList.remove("hidden");
            } else {
                playIcon.classList.remove("hidden");
                pauseIcon.classList.add("hidden");
            }
        }
    });
</script>
